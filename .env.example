# ---- Supabase (Project Settings > API) ----  set these in Vercel too
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, encrypted in Vercel
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Anthropic (school-calendar auto-extraction) ----  server-only; NEVER prefix NEXT_PUBLIC_
# Set in Vercel as an encrypted env var. Used by src/components/school/extract.ts.
ANTHROPIC_API_KEY=sk-ant-...

# ---- Edge function secrets (set with `supabase secrets set`, NOT in Vercel) ----
# RESEND_API_KEY=re_...
# RESEND_FROM=Family Calendar <calendar@yourdomain.com>
# SITE_URL=https://www.lincolnhometime.com
# (SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are injected into functions automatically)
